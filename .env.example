# Database
DATABASE_URL=postgresql+psycopg2://coinglass:coinglass@db:5432/coinglass
POSTGRES_USER=coinglass
POSTGRES_PASSWORD=coinglass

# Public domain for HTTPS (Caddy). Use localhost for local testing.
DOMAIN=localhost
ACME_EMAIL=

# Data sources (comma-separated): binance, bybit, coinglass
DATA_SOURCES=bybit,binance
DEFAULT_DATA_SOURCE=bybit

# Binance API (USDS-M futures)
BINANCE_FAPI_BASE=https://fapi.binance.com

# Bybit API
BYBIT_API_BASE=https://api.bybit.com

# Coinglass API V4 (requires paid API key)
COINGLASS_API_BASE=https://open-api-v4.coinglass.com
COINGLASS_API_KEY=

# Sync settings (days). 0 = unlimited backfill to onboard date.
BACKFILL_DAYS_5M=30
BACKFILL_DAYS_15M=30
BACKFILL_DAYS_1H=30
BACKFILL_DAYS_4H=365
BACKFILL_DAYS_1D=0
BACKFILL_DAYS_1W=0
BACKFILL_DAYS_1M=0

# Update interval in minutes
UPDATE_MINUTES_5M=15
UPDATE_MINUTES_15M=15
UPDATE_MINUTES_1H=60
UPDATE_MINUTES_4H=60
UPDATE_MINUTES_1D=360
UPDATE_MINUTES_1W=360
UPDATE_MINUTES_1M=360

# Rate limiting (milliseconds between requests)
REQUEST_DELAY_MS=120
REQUEST_MAX_RETRIES=5
