{
    # Global options
    email {$ACME_EMAIL:}
}

{$DOMAIN:localhost} {
    # Reverse proxy to FastAPI app
    reverse_proxy web:8000

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Access logging
    log {
        output file /data/log/access.log
    }
}
